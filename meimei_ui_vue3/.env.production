# 页面标题
VITE_SITE_NAME = 槑槑管理系统

# 生产环境配置
VITE_APP_ENV = 'production'

# 槑槑管理系统/生产环境
VITE_APP_BASE_API = '/prod-api'

# 应用基础路径（部署在子路径时配置，如 /abc/，根目录部署则为 /）
VITE_APP_BASE_PATH = '/prodthinkpadwwwgogolecom/'

# 是否在打包时开启压缩，支持 gzip 和 brotli
VITE_BUILD_COMPRESS = gzip

# 开发服务器端口（可通过命令行 --port 覆盖）
VITE_APP_PORT = 8099